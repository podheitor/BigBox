{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BigBox",
  "version": "0.1.0",
  "identifier": "io.github.podheitor.bigbox",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BigBox",
        "width": 1280,
        "height": 760,
        "minWidth": 800,
        "minHeight": 480,
        "resizable": true,
        "decorations": false,
        "center": true,
        "url": "index.html",
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
